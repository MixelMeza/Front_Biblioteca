<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Estado presionado -->
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#D1FAE5"/> <!-- verde más claro -->
        </shape>
    </item>

    <!-- Estado normal -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#FFFFFF"/> <!-- fondo blanco -->
            <stroke android:width="1dp" android:color="#10B981"/> <!-- borde verde -->
        </shape>
    </item>
</selector>